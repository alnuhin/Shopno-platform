# Copy this file to .env and change the values before running in production

PORT=3000

# Long random string used to sign session cookies. Change this to your own value.
SESSION_SECRET=change-this-to-a-long-random-string-before-going-live

# Default Management (admin) account created by the seed script (npm run seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# Node environment: development | production
NODE_ENV=development
