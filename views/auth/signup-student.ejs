<!DOCTYPE html>
<html lang="bn">
<head><%- include('../partials/head', { title: t('student_user') + ' ' + t('signup') }) %></head>
<body>
  <%- include('../partials/topbar') %>
  <div class="container-narrow" style="padding-top:40px; padding-bottom:60px;">
    <div class="card">
      <h1><%= t('student_user') %> — <%= t('signup') %></h1>
      <%- include('../partials/flash') %>

      <form action="/signup/student" method="POST" enctype="multipart/form-data">

        <div class="form-section-title">🔐 <%= t('username') %> / <%= t('password') %></div>
        <div class="form-row">
          <div class="field">
            <label><%= t('username') %> *</label>
            <input type="text" name="username" required />
          </div>
          <div class="field">
            <label><%= t('password') %> *</label>
            <input type="password" name="password" required minlength="6" />
          </div>
        </div>

        <div class="form-section-title">👤 <%= t('personal_info') %></div>
        <div class="form-row">
          <div class="field"><label><%= t('first_name') %> *</label><input type="text" name="first_name" required /></div>
          <div class="field"><label><%= t('last_name') %> *</label><input type="text" name="last_name" required /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('dob') %></label><input type="date" name="dob" /></div>
          <div class="field"><label><%= t('birth_cert_no') %></label><input type="text" name="birth_certificate_no" /></div>
        </div>
        <div class="form-row">
          <div class="field">
            <label><%= t('gender') %></label>
            <div class="radio-group">
              <label><input type="radio" name="gender" value="M" /> <%= lang==='en' ? 'Male' : 'ছেলে' %></label>
              <label><input type="radio" name="gender" value="F" /> <%= lang==='en' ? 'Female' : 'মেয়ে' %></label>
              <label><input type="radio" name="gender" value="Other" /> <%= lang==='en' ? 'Other' : 'অন্যান্য' %></label>
            </div>
          </div>
          <div class="field">
            <label><%= t('religion') %></label>
            <select name="religion">
              <option value="Islam">ইসলাম</option>
              <option value="Hinduism">হিন্দু</option>
              <option value="Christianity">খ্রিষ্টান</option>
              <option value="Buddhism">বৌদ্ধ</option>
              <option value="Other"><%= lang==='en' ? 'Other' : 'অন্যান্য' %></option>
            </select>
          </div>
        </div>
        <div class="field"><label><%= t('upload_photo') %> (<%= lang==='en' ? 'your photo' : 'তোমার ছবি' %>)</label><input type="file" name="student_photo" accept="image/*" /></div>

        <div class="form-section-title">🏫 <%= t('educational_info') %></div>
        <div class="form-row">
          <div class="field"><label><%= t('class_level') %></label><input type="text" name="class_level" /></div>
          <div class="field"><label><%= t('institution_name') %></label><input type="text" name="institution_name" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('institution_eiin') %></label><input type="text" name="institution_eiin" /></div>
          <div class="field"><label><%= t('institution_email') %></label><input type="email" name="institution_email" /></div>
        </div>
        <div class="form-row">
          <div class="field">
            <label><%= t('club_activity') %></label>
            <div class="radio-group">
              <label><input type="radio" name="club_activity" value="yes" /> <%= t('yes') %></label>
              <label><input type="radio" name="club_activity" value="no" checked /> <%= t('no') %></label>
            </div>
          </div>
          <div class="field"><label><%= t('which_club') %></label><input type="text" name="club_name" /></div>
        </div>

        <div class="form-section-title">👪 <%= t('parents_info') %></div>
        <div class="form-row">
          <div class="field"><label><%= t('father_name') %></label><input type="text" name="father_name" /></div>
          <div class="field"><label><%= t('occupation') %></label><input type="text" name="father_occupation" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('nid_number') %> (<%= lang==='en' ? 'father' : 'বাবার' %>)</label><input type="text" name="father_nid" /></div>
          <div class="field"><label><%= t('phone_number') %> (<%= lang==='en' ? 'father' : 'বাবার' %>)</label><input type="tel" name="father_phone" /></div>
        </div>
        <div class="field"><label><%= t('upload_photo') %> (<%= lang==='en' ? 'father' : 'বাবার' %>)</label><input type="file" name="father_photo" accept="image/*" /></div>

        <div class="form-row">
          <div class="field"><label><%= t('mother_name') %></label><input type="text" name="mother_name" /></div>
          <div class="field"><label><%= t('occupation') %></label><input type="text" name="mother_occupation" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('nid_number') %> (<%= lang==='en' ? 'mother' : 'মায়ের' %>)</label><input type="text" name="mother_nid" /></div>
          <div class="field"><label><%= t('phone_number') %> (<%= lang==='en' ? 'mother' : 'মায়ের' %>)</label><input type="tel" name="mother_phone" /></div>
        </div>
        <div class="field"><label><%= t('upload_photo') %> (<%= lang==='en' ? 'mother' : 'মায়ের' %>)</label><input type="file" name="mother_photo" accept="image/*" /></div>

        <div class="field">
          <label><%= t('is_orphan') %></label>
          <div class="radio-group">
            <label><input type="radio" name="is_orphan" value="yes" /> <%= t('yes') %></label>
            <label><input type="radio" name="is_orphan" value="no" checked /> <%= t('no') %></label>
          </div>
          <span class="hint"><%= lang==='en' ? 'If yes, fill the legal guardian fields below.' : 'যদি হ্যাঁ হয়, নিচে আইনগত অভিভাবকের তথ্য দাও।' %></span>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('legal_guardian_name') %></label><input type="text" name="legal_guardian_name" /></div>
          <div class="field"><label><%= t('legal_guardian_relation') %></label><input type="text" name="legal_guardian_relation" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('nid_number') %></label><input type="text" name="legal_guardian_nid" /></div>
          <div class="field"><label><%= t('phone_number') %></label><input type="tel" name="legal_guardian_phone" /></div>
        </div>
        <div class="field"><label><%= t('upload_photo') %> (<%= lang==='en' ? 'legal guardian' : 'অভিভাবকের' %>)</label><input type="file" name="legal_guardian_photo" accept="image/*" /></div>

        <div class="form-section-title">📍 <%= lang==='en' ? 'Address' : 'ঠিকানা' %></div>
        <div class="form-row">
          <div class="field"><label><%= t('present_address') %></label><textarea name="present_address"></textarea></div>
          <div class="field"><label><%= t('permanent_address') %></label><textarea name="permanent_address"></textarea></div>
        </div>

        <div class="form-section-title">📤 <%= t('submit_info') %></div>
        <div class="form-row">
          <div class="field"><label><%= t('phone_number') %></label><input type="tel" name="student_phone" /></div>
          <div class="field"><label><%= lang==='en' ? 'Email' : 'ইমেইল' %></label><input type="email" name="student_email" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('social_media') %></label><input type="text" name="social_media_account" placeholder="Facebook / Instagram profile link" /></div>
          <div class="field"><label><%= t('whatsapp') %></label><input type="tel" name="whatsapp_number" /></div>
        </div>
        <div class="form-row">
          <div class="field"><label><%= t('emergency_contact') %> — <%= lang==='en' ? 'name' : 'নাম' %></label><input type="text" name="emergency_contact_name" /></div>
          <div class="field"><label><%= t('emergency_contact') %> — <%= t('phone_number') %></label><input type="tel" name="emergency_contact_phone" /></div>
        </div>
        <div class="field"><label><%= t('upload_photo') %> (<%= lang==='en' ? 'emergency contact person' : 'জরুরি যোগাযোগের ব্যক্তির' %>)</label><input type="file" name="emergency_contact_photo" accept="image/*" /></div>

        <div class="field">
          <label><%= t('teacher_contact_hint') %> *</label>
          <input type="text" name="teacher_contact" required placeholder="phone or email" />
        </div>

        <div class="upload-grid">
          <div class="field"><label>NID / <%= lang==='en' ? 'Birth Cert (front)' : 'জন্ম নিবন্ধন (সামনে)' %></label><input type="file" name="nid_front" accept="image/*" /></div>
          <div class="field"><label>NID / <%= lang==='en' ? 'Birth Cert (back)' : 'জন্ম নিবন্ধন (পেছনে)' %></label><input type="file" name="nid_back" accept="image/*" /></div>
        </div>

        <div class="checkbox-row">
          <input type="checkbox" name="agree_terms" id="agree_terms" required />
          <label for="agree_terms"><%= t('agree_terms') %></label>
        </div>

        <button type="submit" class="btn btn-primary btn-block"><%= t('submit') %></button>
      </form>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
